# Rinomina in ".env" e compila. NON committare .env.
#
# Le credenziali Telegram (TG_API_ID, TG_API_HASH, TG_PHONE) NON servono qui se hai UniChat:
# vengono lette in automatico da Code/unichat/.env. Impostale sotto solo se vuoi sovrascriverle.
#
# TG_API_ID=123456
# TG_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TG_PHONE=+39333...
# UNICHAT_ENV=C:\Users\Antonio\business-up\Code\unichat\.env   (default già giusto se la struttura è quella)

# Il tuo Telegram ID (proprietario dei contatti)
OWNER_ID=334179105

